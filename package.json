  },
  "scripts": {
    "build": "GATSBY_TELEMETRY_DISABLED=1 NODE_OPTIONS=\"${NODE_OPTIONS:-} --require=./scripts/use-userland-punycode.js\" gatsby clean && GATSBY_TELEMETRY_DISABLED=1 NODE_OPTIONS=\"${NODE_OPTIONS:-} --require=./scripts/use-userland-punycode.js\" gatsby build",
    "develop": "GATSBY_TELEMETRY_DISABLED=1 NODE_OPTIONS=\"${NODE_OPTIONS:-} --require=./scripts/use-userland-punycode.js\" gatsby develop",
    "format": "prettier --write src/**/*.{js,jsx}",
    "new:post": "node scripts/new-blog-post.js",
    "start": "npm run develop",
    "serve": "GATSBY_TELEMETRY_DISABLED=1 NODE_OPTIONS=\"${NODE_OPTIONS:-} --require=./scripts/use-userland-punycode.js\" gatsby serve",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\"",
    "upgrade-interactive": "npm-check --update"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
